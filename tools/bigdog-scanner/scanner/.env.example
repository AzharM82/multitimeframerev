# ── BigDog Trades scanner config (copy to .env on DESKTOP2) ──────────────────

# Finviz Elite — two directional universes (bull + bear). Any /screener?... URL
# is auto-rewritten to the export endpoint. Legacy FINVIZ_SCREENER_URL, if set,
# is used as the bull list.
FINVIZ_API_KEY=
FINVIZ_SCREENER_URL_BULL=https://elite.finviz.com/screener?v=151&f=cap_midover,geo_usa,ind_stocksonly,sh_avgvol_o1000,sh_opt_option,sh_price_o10,ta_sma20_sa50,ta_sma50_sa200,ta_volatility_wo4&ft=4&o=-changeopen
FINVIZ_SCREENER_URL_BEAR=https://elite.finviz.com/screener?v=151&f=cap_midover,geo_usa,ind_stocksonly,sh_avgvol_o1000,sh_opt_option,sh_price_o10,ta_changeopen_d,ta_sma20_pb,ta_sma50_pb,ta_volatility_wo4&ft=4&o=change

# Pushover (instant phone push)
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# WhatsApp (Azure Storage Queue → whatsapp-sidecar drains it)
AZURE_STORAGE_CONNECTION_STRING=
WHATSAPP_QUEUE_NAME=whatsapp-alerts
WHATSAPP_RECEIVER=14253241733

# Portal logging (MTF Reversal portal — /api/bigdog-alert)
SCANNER_API_BASE=https://salmon-river-0a7a0c30f.1.azurestaticapps.net
TIMER_SECRET=

# TOS window (substring of the dedicated BigDog chart window title; empty = interactive pick)
TOS_SCANNER_WINDOW=
SCANNER_LOAD_WAIT_S=2.0
SCANNER_KEY_INTERVAL_S=0.025

# ── Scoring (optional; defaults shown) ───────────────────────────────────────
# Score is computed ON-CHART (BD SC chip); these drive the alert gate + the
# Python fallback recompute. Bull alerts at score>=+ALERT_MIN, bear at <=-ALERT_MIN.
ALERT_MIN=3
BUY_PCT_MIN=70          # must match the study's bdBuyThresh input
