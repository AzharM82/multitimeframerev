# Copy to .env and fill in. .env is gitignored.

# Finviz Elite — get auth from your account. Screener URL can be any /screener?...
# you've built; the script will rewrite it to /export.ashx automatically.
FINVIZ_API_KEY=
FINVIZ_SCREENER_URL=https://elite.finviz.com/screener?v=151&f=cap_5to,sh_avgvol_o1000,sh_opt_option,sh_price_o50,sh_relvol_o1,ta_sma200_pa,ta_sma50_pa,ta_volatility_wo4&ft=4&o=-changeopen&c=0,1,2,3,4,6,127,84,95,96,97,42,43,60,67,65,66&preset=s151414360

# WhatsApp delivery — sidecar drains this Azure Storage Queue.
# Put the receiver's E.164 number WITHOUT the leading '+'.
AZURE_STORAGE_CONNECTION_STRING=
WHATSAPP_QUEUE_NAME=whatsapp-alerts
WHATSAPP_RECEIVER=14253241733

# TOS chart window — substring of the dedicated chart's window title.
# Set TOS chart's "Description" or layout name to something unique like "Scanner".
TOS_SCANNER_WINDOW=Scanner

# Portal (where alerts get logged → Day Trades page).
SCANNER_API_BASE=https://salmon-river-0a7a0c30f.1.azurestaticapps.net
TIMER_SECRET=

# Tunables (defaults shown).
SCANNER_FRESH_MINUTES=10
SCANNER_LOAD_WAIT_S=2.0
SCANNER_KEY_INTERVAL_S=0.025
